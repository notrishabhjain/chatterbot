<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <cloud-backup>
        <include domain="database" path="twin.db" />
        <!-- Never back up API keys to the cloud. -->
        <exclude domain="sharedpref" path="twin_secrets.xml" />
    </cloud-backup>
    <device-transfer>
        <include domain="database" path="twin.db" />
    </device-transfer>
</data-extraction-rules>
